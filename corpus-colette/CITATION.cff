    orcid: "https://orcid.org/0000-0003-3297-1947"
  - name: "Centre Hépato-Biliaire Henri Bismuth, Hôpital Paul-Brousse (AP-HP)"
license: CC-BY-SA-4.0
keywords:
  - therapeutic patient education
  - liver transplantation
  - hepatology
  - medical corpus
  - health open data
  - langue française

